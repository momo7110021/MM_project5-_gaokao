        "probability_interval": [0.5000, 0.8500],
        "recommendation_tier": "safe",
        "fit_score": 0.50,
        "career_score": 0.85,
        "city_score": 0.55,
        "family_score": 0.50,
        "risk_level": "low",
        "risk_reason": "保底志愿",
