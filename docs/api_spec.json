        "modification_suggestion": "该志愿较稳定，可考虑作为主要选择。",
        "review_required": false,
        "source_trace": {"source_url": "", "source_name": "admission_plan", "crawl_time": "2026-05-15 20:00:00", "data_version": "simulated_v3.0", "source_type": "simulated"}
      }],
      "statistics": {
        "rush_count": 8,
        "stable_count": 12,
        "safe_count": 12,
        "bottom_count": 8,
        "overall_score": 0.2503,
        "overall_risk_level": "medium"
      },
      "risk_assessment": {
        "overall_risk_score": 0.1805,
        "risk_level": "medium",
        "slip_risk": {"score": 0.0500, "level": "low", "trigger_reason": "", "modification_suggestion": "", "review_required": false},
        "withdrawal_risk": {"score": 0.0200, "level": "low", "trigger_reason": "", "modification_suggestion": "", "review_required": false},
        "adjustment_risk": {"score": 0.1500, "level": "medium", "trigger_reason": "专业组内部冷热差异大", "modification_suggestion": "建议关注调剂规则", "review_required": false},
        "cold_major_risk": {"score": 0.1000, "level": "low", "trigger_reason": "", "modification_suggestion": "", "review_required": false},
        "employment_risk": {"score": 0.0800, "level": "low", "trigger_reason": "", "modification_suggestion": "", "review_required": false},
        "region_risk": {"score": 0.1200, "level": "low", "trigger_reason": "", "modification_suggestion": "", "review_required": false},
        "risk_reason": ["Q2: 稳志愿过少"],
        "modification_suggestion": "建议增加至少2个保或垫级别志愿",
        "review_required": false
      }
    }
  },
  "notes": [
    "所有数据均为模拟数据，仅供教学和测试使用",
    "admit_probability 上限为 0.99，绝不输出 1.0 或 100%",
    "recommendation_tier 由模型二和模型三联合决定，以模型二的概率映射为准",
    "risk_assessment 中六类风险各为独立 dict，含 score/level/trigger_reason/modification_suggestion/review_required",
    "source_trace 每行必含 5 字段(source_url/source_name/crawl_time/data_version/source_type)",
    "真实上线前必须使用按省份、科类、选科组合分层的历史数据重新训练、回测和校准"
  ]
}
